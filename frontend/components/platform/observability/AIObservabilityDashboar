"use client";

import { useEffect, useState } from "react";

import type {
  AIObservabilityStatus,
  AIRequestMetric,
} from "@/lib/platform/observability/ai-observability-types";

interface ApiResponse {
  status: AIObservabilityStatus;
  metrics: AIRequestMetric[];
}

function MetricCard({
  title,
  value,
}: {
  title: string;
  value: string | number;
}) {
  return (
    <div className="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <div className="text-sm text-slate-500">{title}</div>
      <div className="mt-2 text-2xl font-bold text-slate-900">{value}</div>
    </div>
  );
}

export default function AIObservabilityDashboard() {
  const [data, setData] = useState<ApiResponse | null>(null);

  async function loadDashboard() {
    const response = await fetch("/api/platform/observability", {
      cache: "no-store",
    });

    const result = (await response.json()) as ApiResponse;

    setData(result);
  }

  async function generateDemoMetric() {
    await fetch("/api/platform/observability", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        id: `metric-${Date.now()}`,
        tenantId: "demo",
        provider: "mock",
        model: "mock-llm",
        promptCategory: "rag",
        latencyMs: 420,
        inputTokens: 520,
        outputTokens: 180,
        totalTokens: 700,
        estimatedCost: 0.0014,
        status: "success",
        createdAt: new Date().toISOString(),
      }),
    });

    await loadDashboard();
  }

  useEffect(() => {
    void loadDashboard();
  }, []);

  const status = data?.status;
  const metrics = data?.metrics ?? [];

  return (
    <section className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-xl font-bold text-slate-900">
            AI Observability
          </h2>

          <p className="text-sm text-slate-500">
            Monitor AI usage, latency, token consumption and estimated cost.
          </p>
        </div>

        <button
          type="button"
          onClick={generateDemoMetric}
          className="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700"
        >
          Generate Demo Metric
        </button>
      </div>

      <div className="grid gap-4 md:grid-cols-5">
        <MetricCard
          title="Requests"
          value={status?.totalRequests ?? 0}
        />

        <MetricCard
          title="Successful"
          value={status?.successfulRequests ?? 0}
        />

        <MetricCard
          title="Failed"
          value={status?.failedRequests ?? 0}
        />

        <MetricCard
          title="Tokens"
          value={status?.totalTokens ?? 0}
        />

        <MetricCard
          title="Avg Latency"
          value={`${status?.averageLatency ?? 0} ms`}
        />
      </div>

      <div className="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div className="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700">
          Recent AI Requests
        </div>

        <div className="overflow-x-auto">
          <table className="min-w-full text-left text-sm">
            <thead className="bg-slate-50 text-xs uppercase text-slate-500">
              <tr>
                <th className="px-4 py-3">Provider</th>
                <th className="px-4 py-3">Model</th>
                <th className="px-4 py-3">Prompt</th>
                <th className="px-4 py-3">Tokens</th>
                <th className="px-4 py-3">Latency</th>
                <th className="px-4 py-3">Status</th>
              </tr>
            </thead>

            <tbody className="divide-y divide-slate-100">
              {metrics.length === 0 ? (
                <tr>
                  <td colSpan={6} className="px-4 py-6 text-slate-500">
                    No AI metrics recorded.
                  </td>
                </tr>
              ) : (
                metrics.map((metric) => (
                  <tr key={metric.id}>
                    <td className="px-4 py-3">{metric.provider}</td>
                    <td className="px-4 py-3">{metric.model}</td>
                    <td className="px-4 py-3">{metric.promptCategory}</td>
                    <td className="px-4 py-3">{metric.totalTokens}</td>
                    <td className="px-4 py-3">{metric.latencyMs} ms</td>
                    <td className="px-4 py-3">{metric.status}</td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  );
}