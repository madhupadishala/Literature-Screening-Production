NODE_ENV=production
APP_NAME=ClinixAI Literature Screening
APP_VERSION=0.1.0
APP_REGION=centralindia
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clinixai
DATABASE_SSL_MODE=require
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10
AI_PROVIDER=groq
GROQ_API_KEY=replace-in-azure-secret
GROQ_MODEL=llama-3.3-70b-versatile
EVIDENCE_STORE_BACKEND=database
KNOWLEDGE_ROOT=/app/knowledge
CLINIXAI_KNOWLEDGE_ROOT=/app/knowledge
INTERNAL_MONITORING_TOKEN=replace-with-at-least-32-random-characters
BUILD_SHA=replace-with-git-commit-sha
RELEASE_VERSION=0.1.0
RELEASE_BASE_URL=https://replace-with-azure-container-app-fqdn
ALLOW_DEMO_PRINCIPAL=false
DEFAULT_TENANT_KEY=demo-tenant
PORT=3000
HOSTNAME=0.0.0.0
